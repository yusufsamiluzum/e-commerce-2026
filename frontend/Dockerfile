# Stage 1: Build the Angular app
FROM node:22-alpine AS builder
WORKDIR /app
COPY package.json package-lock.json* ./
RUN npm ci
COPY . .
# This builds both the browser and server output for SSR
RUN npm run build

# Stage 2: Run the SSR Server
FROM node:22-alpine
WORKDIR /app
COPY --from=builder /app/dist ./dist
COPY --from=builder /app/package.json ./
# Default Angular SSR port
EXPOSE 4000
# Run the Node server generated by Angular Universal/SSR
CMD ["npm", "run", "serve:ssr:datapulse-frontend"]
