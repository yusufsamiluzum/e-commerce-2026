# === LLM Provider Ayarları (Admin panelinden değiştirilebilir) ===

# OpenAI
OPENAI_API_KEY=sk-your-key-here

# Anthropic (Claude) — opsiyonel, admin panelinden seçilirse gerekli
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Google Gemini — opsiyonel
GOOGLE_API_KEY=AIzaSyD74A1-GUY8ORllzYSlDrEDKy7xIdblD28

# Ollama — opsiyonel, yerel LLM için
OLLAMA_BASE_URL=http://localhost:11434

# Groq — opsiyonel, süper hızlı inference için
GROQ_API_KEY=gsk-your-key-here

# Varsayılan LLM (admin ayarından override edilir)
